# Clé API OpenRouter (accès multi-modèles)
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXX

# Modèle LLM (défaut : moonshotai/kimi-k2.6)
LLM_MODEL=moonshotai/kimi-k2.6

# Airtable — même PAT que le front, ou un PAT dédié
AIRTABLE_PAT=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=apprtejZaap5ouqGm

# Port du serveur Express (défaut : 3001)
PORT=3001

# Presidio — API d'anonymisation PII (optionnel, V2)
# PRESIDIO_URL=http://localhost:5080

# CORS — origine autorisée (front React)
CORS_ORIGIN=http://localhost:3000
