# ──────────────────────────────────────────────
#  Airtable – configuration obligatoire
# ──────────────────────────────────────────────

# Personal Access Token (recommandé) ou API Key legacy
# Générer sur https://airtable.com/create/tokens
REACT_APP_AIRTABLE_TOKEN=patXXXXXXXXXXXXXX

# ID de votre base (ex: appXXXXXXXXXXXXXX)
# Visible dans l'URL de votre base : airtable.com/appXXXXXXXXXXXXXX/...
REACT_APP_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ──────────────────────────────────────────────
#  Airtable – noms de tables (optionnel, valeurs par défaut ci-dessous)
# ──────────────────────────────────────────────

# Nom exact de la table Dossiers dans votre base (défaut : "Dossiers")
REACT_APP_AIRTABLE_TABLE_NAME=Dossiers

# Nom exact de la table Contacts / Clients (défaut : "Contacts")
REACT_APP_AIRTABLE_CONTACTS_TABLE=Contacts

# Nom exact du champ de liaison Dossier → Contact
# Exemples : "Contact", "Contacts", "Fiche contact", "Client", "Clients", "Contact(s)"
# Laisser vide pour activer la détection automatique
REACT_APP_AIRTABLE_CONTACT_LINK_FIELD=

# Nom exact du champ pièce jointe RIB sur un dossier (défaut : "RIB")
REACT_APP_DOSSIER_RIB_FIELD=RIB

# ──────────────────────────────────────────────
#  n8n – webhooks (obligatoire pour l'extraction RI/devis, le matching IA
#  et l'archivage Dropbox des documents Cabinet : permis, carte grise, FIC, devis…)
# ──────────────────────────────────────────────

# URL de base de l'instance n8n
REACT_APP_N8N_BASE_URL=https://n8n2.reaktimo.com

# Chemin du webhook d'archivage Dropbox des documents Cabinet (workflow
# "Upload Document Cabinet"). Sans cette variable, les Documents sont bien
# créés dans Airtable mais le fichier n'est JAMAIS envoyé sur Dropbox
# (Dropbox_Path reste vide) — impacte permis/carte grise/FIC/etc.
REACT_APP_N8N_UPLOAD_WEBHOOK=/webhook/upload-document-cabinet

# ──────────────────────────────────────────────
#  Cloudinary – upload RIB (optionnel)
# ──────────────────────────────────────────────
# Sans ces variables, l'upload RIB fonctionne en mode démo (pas d'écriture Airtable)

REACT_APP_CLOUDINARY_CLOUD_NAME=
REACT_APP_CLOUDINARY_UPLOAD_PRESET=

# ──────────────────────────────────────────────
#  Gemini / IA (optionnel)
# ──────────────────────────────────────────────
GEMINI_API_KEY=

# ──────────────────────────────────────────────
#  Accès propriétaire / développeur (fallback local)
# ──────────────────────────────────────────────
# Utilisé quand l'API Airtable est inaccessible (quota, réseau).
# Rôle Admin, bypass la table Collaborateurs_Cabinet_Client.
REACT_APP_OWNER_EMAIL=
REACT_APP_OWNER_PASSWORD=
